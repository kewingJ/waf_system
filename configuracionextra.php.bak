        <script type="text/javascript">
            // $(document).ajaxStart(function () {
           //      Pace.restart()
           // });

            //Date picker
            $('#datepicker').datepicker({
                autoclose: true,
                format: 'dd/mm/yyyy',
                startDate: '+7d',
            });

            $(function() { "use strict";
                $(".multi-select").multiSelect({
                    selectableHeader: "<input type='text' class='search-input form-control' autocomplete='off' placeholder='Buscar...'>",
                    selectionHeader: "<input type='text' class='search-input form-control' autocomplete='off' placeholder='Buscar...'>",
                    afterInit: function(ms)
                    {
                        var that = this,
                            $selectableSearch = that.$selectableUl.prev(),
                            $selectionSearch = that.$selectionUl.prev(),
                            selectableSearchString = '#'+that.$container.attr('id')+' .ms-elem-selectable:not(.ms-selected)',
                            selectionSearchString = '#'+that.$container.attr('id')+' .ms-elem-selection.ms-selected';

                            that.qs1 = $selectableSearch.quicksearch(selectableSearchString)
                            .on('keydown', function(e){
                            if (e.which === 40){
                                that.$selectableUl.focus();
                                return false;
                            }
                            });

                            that.qs2 = $selectionSearch.quicksearch(selectionSearchString)
                            .on('keydown', function(e){
                            if (e.which == 40){
                                that.$selectionUl.focus();
                                return false;
                            }
                            });
                    },
                    afterSelect: function(){
                        this.qs1.cache();
                        this.qs2.cache();
                    },
                    afterDeselect: function(){
                        this.qs1.cache();
                        this.qs2.cache();
                    }
                });
                $(".ms-container").append('<i class="glyph-icon icon-exchange"></i>');
            });
        </script>

        <!-- actualizar datos de sitio -->
        <script type="text/javascript">
            $(document).ready(function(){
                //respaldo
                $('#updateSitio').click(function () {
                    $.ajax({
                      url: 'controller/ajax_backup_sitio.php', 
                        success: function (result) {
                            not6();
                            setTimeout("location.href = 'configuracionextra.php'",3000);
                        }
                    })
                });
            });
        </script>

        <!-- procesar paises geo ip-->
        <script type="text/javascript">
            $(document).ready(function(){
                //procesar geo ip
                $(document).on('click', '#btnProcesarPais', function(e){
                    e.preventDefault();
                    var DataString = $('#form-pais').serialize();
                    $.ajax({
                        type: 'POST',
                        url: 'controller/g_geoip.php',
                        data: DataString,
                        success: function(data) {
                            if (data == 'bien') {
                                not1();
                                // alert(data);
                                setTimeout("location.href = 'configuracionextra.php'",3000);
                            } else {
                                not2();
                                // alert(data);
                            }
                        }
                    });
                });
            });
        </script> 

        <!-- llamar comando -->
        <script type="text/javascript">
            $(document).ready(function(){
                $(document).on('click', '#btnCambios', function(e){
                    e.preventDefault();
                    $.ajax({
                        type: 'POST',
                        url: 'controller/procesar_cambios.php',
                        data: { dato: 'aplicar' },
                        success: function (result) {
                            //alert(result);
                            not6();
                            setTimeout("location.href = 'configuracionextra.php'",3000);
                        }
                    }); 
                });
            });
        </script>

        <!-- procesar respaldos -->
        <script type="text/javascript">
             $(document).ready(function(){
                //procesar
                $(document).on('click', '.btnRestaurar', function(e){
                    var id_respaldo = $(this).data('id');
                    var tipo_respaldo = $(this).data('tipo');
                    var parametro = {
                        "id_respaldo" : id_respaldo
                    }
                    if(tipo_respaldo == 'sitio'){
                        $.ajax({
                            type: 'POST',
                            url: 'controller/ajax_procesar_backupSitio.php',
                            data: parametro,
                            success: function(data) {
                                if (data == 'bien') {
                                    not6();
                                    setTimeout("location.href = 'configuracionextra.php'",2000);
                                } else{
                                    not5();
                                }
                            }
                        });
                    } else {
                        $.ajax({
                            type: 'POST',
                            url: 'controller/restore_database.php',
                            data: parametro,
                            success: function(data) {
                                if (data == 'bien') {
                                    not6();
                                    setTimeout("location.href = 'configuracionextra.php'",2000);
                                } else{
                                    not5();
                                }
                            }
                        });
                    }
                });
            });
        </script>

