                                            $i = 1;
                                            while($row = mysqli_fetch_array($query)){
                                                $option = '';
                                                switch($row['tipo_config']){
                                                    case 'ssl':
                                                        $imagen = '<img src="img/ssl.png" style="width: 25px;"/>';
                                                        $option = '
                                                        <li>
                                                          <a href="#0" 
