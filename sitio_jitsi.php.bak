                                                            <img src="img/geo_ip.webp" style="width: 15px;"> Activar Geo Ip
                                                          </a>
                                                        </li>
                                                        ';
                                                        break;
                                                    case 'load':
                                                        $imagen = '<img src="img/load.png" style="width: 25px;"/>';
                                                        $option = '
                                                        <li>
                                                          <a href="#0" 
                                                             data-id="'.$row['id_sitio'].'" class="btn3">
                                                            <img src="img/geo_ip.webp" style="width: 15px;"> Activar Geo Ip
                                                          </a>
                                                        </li>
